# Ignore all files by default (whitelist approach)
*

# Except the following
!.gitignore
!.env.example
!.python-version
!.pre-commit-config.yaml
!README.md
!readme.md
!requirements.txt
!pyproject.toml

# Source package
!src/
!src/restaurant_rankings/
!src/restaurant_rankings/*.py

# Tests
!tests/
!tests/*.py
!tests/fixtures/
!tests/fixtures/*.json

# Keep the output directory but ignore its contents
!output/
output/*
!output/.gitkeep
